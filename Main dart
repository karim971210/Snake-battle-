class GamePainter extends CustomPainter {
  final List<SnakeEntity> snakes;
  final List<FoodItem> foods;
  final Size screenSize;

  GamePainter(this.snakes, this.foods, this.screenSize);

  @override
  void paint(Canvas canvas, Size size) {
    // Draw glow effect for food
    for (final food in foods) {
      final glowPaint = Paint()
        ..color = food.color.withAlpha(40)
        ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 12);
      canvas.drawCircle(food.pos, 22, glowPaint);
      
      // Draw food
      final textPainter = TextPainter(
        text: TextSpan(text: food.emoji, style: const TextStyle(fontSize: 30)),
        textDirection: TextDirection.ltr,
      );
      textPainter.layout();
      textPainter.paint(canvas, food.pos - Offset(textPainter.width / 2, textPainter.height / 2));
    }

    // Draw snakes
    for (final snake in snakes) {
      if (!snake.alive) continue;
      
      // Draw body first
      for (int i = 0; i < snake.body.length - 1; i++) {
        _drawSegment(canvas, snake, i, false);
      }
      // Draw head last
      if (snake.body.isNotEmpty) {
        _drawSegment(canvas, snake, snake.body.length - 1, true);
      }
    }
  }

  void _drawSegment(Canvas canvas, SnakeEntity snake, int index, bool isHead) {
    final pos = snake.body[index];
    final double size = isHead ? 28 : 22;
    
    // Calculate angle for smooth rotation
    double angle = snake.angle;
    if (index < snake.body.length - 1) {
      final nextPos = snake.body[index + 1];
      angle = math.atan2(nextPos.dy - pos.dy, nextPos.dx - pos.dx);
    }
    
    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.rotate(angle);
    
    // Shadow effect
    final shadowPaint = Paint()
      ..color = Colors.black38
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 4);
    canvas.drawRRect(
      RRect.fromRectAndRadius(
        Rect.fromCenter(center: const Offset(2, 2), width: size, height: size),
        Radius.circular(isHead ? 14 : 11),
      ),
      shadowPaint,
    );
    
    // Main body
    final paint = Paint()..color = snake.color;
    canvas.drawRRect(
      RRect.fromRectAndRadius(
        Rect.fromCenter(center: Offset.zero, width: size, height: size),
        Radius.circular(isHead ? 14 : 11),
      ),
      paint,
    );
    
    // Highlight effect
    if (!isHead) {
      final highlightPaint = Paint()
        ..color = Colors.white.withAlpha(40)
        ..style = PaintingStyle.fill;
      canvas.drawRRect(
        RRect.fromRectAndRadius(
          Rect.fromCenter(center: const Offset(-3, -3), width: size - 6, height: size - 6),
          Radius.circular((size - 6) / 2),
        ),
        highlightPaint,
      );
    }
    
    // Eyes for head
    if (isHead) {
      final eyePaint = Paint()..color = Colors.white;
      canvas.drawCircle(const Offset(-9, -8), 5, eyePaint);
      canvas.drawCircle(const Offset(9, -8), 5, eyePaint);
      
      final pupilPaint = Paint()..color = Colors.black;
      canvas.drawCircle(const Offset(-8, -8), 3, pupilPaint);
      canvas.drawCircle(const Offset(10, -8), 3, pupilPaint);
      
      // Tongue
      final tonguePaint = Paint()..color = Colors.red;
      canvas.drawLine(const Offset(0, 12), const Offset(0, 20), tonguePaint..strokeWidth = 3);
    }
    
    canvas.restore();
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

class RadarPainter extends CustomPainter {
  final Offset player;
  final List<FoodItem> foods;
  final Size screenSize;

  RadarPainter(this.player, this.foods, this.screenSize);

  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = 1.5
      ..color = Colors.white54;
    
    canvas.drawRect(Offset.zero & size, paint);
    
    final double scaleX = size.width / screenSize.width;
    final double scaleY = size.height / screenSize.height;
    
    // Draw player
    paint.color = Colors.greenAccent;
    paint.style = PaintingStyle.fill;
    canvas.drawCircle(Offset(player.dx * scaleX, player.dy * scaleY), 4, paint);
    
    // Draw food
    paint.color = Colors.yellow;
    for (final food in foods) {
      canvas.drawCircle(Offset(food.pos.dx * scaleX, food.pos.dy * scaleY), 2.5, paint);
    }
    
    // Draw radar sweep effect
    paint.color = Colors.white.withAlpha(30);
    paint.style = PaintingStyle.fill;
    // Sweep animation would go here
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

