class SnakeEntity {
  final List<Offset> body;
  final Color color;
  final String skinId;
  double angle;
  bool isPlayer;
  bool alive;

  SnakeEntity({
    required this.body,
    required this.color,
    required this.skinId,
    this.angle = 0,
    this.isPlayer = false,
    this.alive = true,
  });

  Offset get head => body.last;
}

class FoodItem {
  Offset pos;
  final String emoji;
  final Color color;

  FoodItem({required this.pos, required this.emoji, required this.color});
}

const List<String> _fruitEmojis = ['🍎', '🍌', '🍉', '🍒', '🍊', '🍍', '🥝', '🥭', '🍓', '🍇', '🍑', '🍒'];
const List<Color> _fruitColors = [Colors.red, Colors.orange, Colors.purple, Colors.green, Colors.yellow, Colors.pink, Colors.blue];

class GamePlayScreen extends StatefulWidget {
  const GamePlayScreen({super.key});

  @override
  State<GamePlayScreen> createState() => _GamePlayScreenState();
}

class _GamePlayScreenState extends State<GamePlayScreen> with TickerProviderStateMixin {
  final math.Random _rnd = math.Random();
  late List<SnakeEntity> snakes;
  late List<FoodItem> foods;
  double angle = 0;
  bool isTurbo = false;
  bool isDanger = false;
  DateTime? gameStartTime;
  Timer? gameTimer;
  Timer? movementTimer;
  
  // Smooth movement
  late AnimationController _smoothController;
  
  // Parallax background
  double _backgroundOffsetX = 0;
  double _backgroundOffsetY = 0;
  
  // Health and invincibility
  int _playerHealth = 3;
  bool _isInvincible = true;
  DateTime? _lastDamageTime;
  
  // Progressive speed
  double _baseSpeed = 3.5;
  double _currentSpeed = 3.5;
  
  // Visual effects
  double _shakeOffset = 0;
  DateTime? _shakeEndTime;
  
  AudioPlayer? backgroundMusic;
  bool assetsLoaded = false;
  Size screenSize = Size.zero;

  @override
  void initState() {
    super.initState();
    
    _smoothController = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 50),
    )..addListener(() {
      if (mounted) setState(() {});
    });
    
    _startMusic();
    
    // Grace period
    _isInvincible = true;
    Future.delayed(const Duration(seconds: 2), () {
      if (mounted) setState(() => _isInvincible = false);
    });
    
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (!mounted) return;
      screenSize = MediaQuery.of(context).size;
      _resetGame();
      _startGameLoop();
    });
  }

  void _startMusic() {
    if (!GameSettings.soundEnabled) return;
    backgroundMusic?.dispose();
    backgroundMusic = AudioPlayer();
    backgroundMusic!.setReleaseMode(ReleaseMode.loop);
    backgroundMusic!.play(AssetSource('audio/music.mp3'));
  }

  void _startGameLoop() {
    gameTimer?.cancel();
    movementTimer?.cancel();
    
    gameTimer = Timer.periodic(const Duration(milliseconds: 16), (_) {
      if (mounted) _updateGame();
    });
    
    movementTimer = Timer.periodic(const Duration(milliseconds: 80), (_) {
      if (mounted) _updateMovement();
    });
  }

  void _resetGame() {
    gameStartTime = DateTime.now();
    GameSettings.totalPoints = 0;
    GameSettings.level = 1;
    _playerHealth = 3;
    _currentSpeed = _baseSpeed;
    _backgroundOffsetX = 0;
    _backgroundOffsetY = 0;
    _shakeOffset = 0;
    
    final center = Offset(screenSize.width / 2, screenSize.height / 2);
    
    // Player snake with 5 segments
    final playerBody = <Offset>[
      Offset(center.dx - 40, center.dy),
      Offset(center.dx - 30, center.dy),
      Offset(center.dx - 20, center.dy),
      Offset(center.dx - 10, center.dy),
      Offset(center.dx, center.dy),
    ];
    
    // Enemies at safe distance
    final enemy1Start = Offset(80, screenSize.height / 2);
    final enemy2Start = Offset(screenSize.width - 80, screenSize.height / 2);
    
    snakes = [
      SnakeEntity(
        body: playerBody,
        color: GameSettings.currentSkin.color,
        skinId: GameSettings.currentSkin.id,
        angle: 0,
        isPlayer: true,
        alive: true,
      ),
      SnakeEntity(
        body: [
          Offset(enemy1Start.dx, enemy1Start.dy - 30),
          Offset(enemy1Start.dx, enemy1Start.dy - 15),
          Offset(enemy1Start.dx, enemy1Start.dy),
          Offset(enemy1Start.dx, enemy1Start.dy + 15),
          Offset(enemy1Start.dx, enemy1Start.dy + 30),
        ],
        color: Colors.blueAccent,
        skinId: 'ocean',
        angle: math.pi / 2,
        isPlayer: false,
        alive: true,
      ),
      SnakeEntity(
        body: [
          Offset(enemy2Start.dx - 40, enemy2Start.dy),
          Offset(enemy2Start.dx - 30, enemy2Start.dy),
          Offset(enemy2Start.dx - 20, enemy2Start.dy),
          Offset(enemy2Start.dx - 10, enemy2Start.dy),
          Offset(enemy2Start.dx, enemy2Start.dy),
          Offset(enemy2Start.dx + 10, enemy2Start.dy),
        ],
        color: Colors.pinkAccent,
        skinId: 'sunset',
        angle: -math.pi / 2,
        isPlayer: false,
        alive: true,
      ),
    ];
    
    foods = List.generate(12, (_) => _randomFood());
    isDanger = false;
    angle = 0;
  }

  FoodItem _randomFood() {
    return FoodItem(
      pos: Offset(
        _rnd.nextDouble() * (screenSize.width - 80) + 40,
        _rnd.nextDouble() * (screenSize.height - 80) + 40,
      ),
      emoji: _fruitEmojis[_rnd.nextInt(_fruitEmojis.length)],
      color: _fruitColors[_rnd.nextInt(_fruitColors.length)],
    );
  }

  void _updateGame() {
    if (!mounted) return;
    
    // Update progressive speed based on points
    _currentSpeed = _baseSpeed + (GameSettings.totalPoints / 150) * 0.4;
    if (_currentSpeed > 8.5) _currentSpeed = 8.5;
    
    // Update level
    final int newLevel = (GameSettings.totalPoints ~/ 100) + 1;
    if (newLevel > GameSettings.level) {
      GameSettings.level = newLevel;
      foods.addAll(List.generate(2, (_) => _randomFood()));
      
      if (GameSettings.soundEnabled) {
        AudioPlayer().play(AssetSource('audio/levelup.mp3'));
      }
    }
    
    // Update parallax background
    final playerSnake = snakes.firstWhere((s) => s.isPlayer);
    _backgroundOffsetX += (playerSnake.head.dx - screenSize.width / 2) * 0.015;
    _backgroundOffsetY += (playerSnake.head.dy - screenSize.height / 2) * 0.015;
    
    if (_backgroundOffsetX.abs() > screenSize.width) _backgroundOffsetX = 0;
    if (_backgroundOffsetY.abs() > screenSize.height) _backgroundOffsetY = 0;
    
    // Update danger status
    isDanger = snakes
        .where((s) => !s.isPlayer && s.alive)
        .any((enemy) => (playerSnake.head - enemy.head).distance < 150);
    
    // Update shake effect
    if (_shakeEndTime != null && DateTime.now().isAfter(_shakeEndTime!)) {
      _shakeOffset = 0;
      _shakeEndTime = null;
    } else if (_shakeEndTime != null) {
      _shakeOffset = (_rnd.nextDouble() - 0.5) * 4;
    }
    
    setState(() {});
  }

  void _updateMovement() {
    if (!mounted) return;
    
    final playerSnake = snakes.firstWhere((s) => s.isPlayer);
    if (playerSnake.alive) {
      playerSnake.angle = angle;
    }
    
    for (final snake in snakes) {
      if (!snake.alive) continue;
      
      if (!snake.isPlayer) {
        _updateEnemyAngle(snake);
      }
      
      final double speedMultiplier = snake.isPlayer ? 1.0 : 0.55;
      final double turboMultiplier = (isTurbo && snake.isPlayer) ? 1.9 : 1.0;
      final double speed = _currentSpeed * speedMultiplier * turboMultiplier;
      
      final head = snake.head;
      Offset nextHead = Offset(
        head.dx + math.cos(snake.angle) * speed,
        head.dy + math.sin(snake.angle) * speed,
      );
      
      // Wrap around screen with padding
      if (nextHead.dx < -40) nextHead = Offset(screenSize.width + 40, nextHead.dy);
      if (nextHead.dx > screenSize.width + 40) nextHead = Offset(-40, nextHead.dy);
      if (nextHead.dy < -40) nextHead = Offset(nextHead.dx, screenSize.height + 40);
      if (nextHead.dy > screenSize.height + 40) nextHead = Offset(nextHead.dx, -40);
      
      // Smooth interpolation
      final currentHead = snake.body.last;
      final smoothedPosition = Offset.lerp(currentHead, nextHead, 0.22)!;
      
      snake.body.add(smoothedPosition);
      
      // Check food collision
      bool ate = false;
      for (int i = 0; i < foods.length; i++) {
        if ((smoothedPosition - foods[i].pos).distance < 28) {
          foods.removeAt(i);
          foods.add(_randomFood());
          
          if (snake.isPlayer) {
            GameSettings.totalPoints += 10;
            if (GameSettings.totalPoints > GameSettings.highScore) {
              GameSettings.highScore = GameSettings.totalPoints;
            }
            
            if (GameSettings.soundEnabled) {
              AudioPlayer().play(AssetSource('audio/eat.mp3'));
            }
            if (GameSettings.vibrationEnabled) {
              Vibration.vibrate(duration: 50);
            }
            
            // Trigger shake effect
            _shakeEndTime = DateTime.now().add(const Duration(milliseconds: 100));
          }
          
          // Grow snake
          snake.body.insert(0, snake.body.first);
          ate = true;
          break;
        }
      }
      
      if (!ate && snake.body.length > 3) {
        snake.body.removeAt(0);
      }
    }
    
    // Check collisions
    _checkCollisions();
    
    // Check if player lost
    if (_playerLost(playerSnake)) {
      _gameOver();
    }
    
    setState(() {});
  }

  bool _playerLost(SnakeEntity player) {
    if (!player.alive) return true;
    
    // Invincibility grace period
    if (_isInvincible) return false;
    
    final head = player.head;
    
    // Self collision (skip first 3 segments)
    for (int i = 0; i < player.body.length - 4; i++) {
      if ((head - player.body[i]).distance < 18) {
        _applyDamage();
        return false;
      }
    }
    
    // Enemy collision
    for (final enemy in snakes.where((s) => !s.isPlayer && s.alive)) {
      for (final segment in enemy.body) {
        if ((head - segment).distance < 22) {
          _applyDamage();
          return false;
        }
      }
    }
    
    return false;
  }

  void _applyDamage() {
    // Prevent multiple rapid damage
    if (_lastDamageTime != null && 
        DateTime.now().difference(_lastDamageTime!).inMilliseconds < 800) {
      return;
    }
    
    _lastDamageTime = DateTime.now();
    _playerHealth--;
    
    if (GameSettings.vibrationEnabled) {
      Vibration.vibrate(duration: 200);
    }
    
    if (GameSettings.soundEnabled) {
      AudioPlayer().play(AssetSource('audio/hit.mp3'));
    }
    
    // Trigger shake
    _shakeEndTime = DateTime.now().add(const Duration(milliseconds: 200));
    
    if (_playerHealth <= 0) {
      _gameOver();
    } else {
      // Knockback effect
      final playerSnake = snakes.firstWhere((s) => s.isPlayer);
      final knockbackDirection = Offset(
        -math.cos(playerSnake.angle) * 35,
        -math.sin(playerSnake.angle) * 35,
      );
      
      final newHead = playerSnake.head + knockbackDirection;
      playerSnake.body.add(newHead);
      
      if (playerSnake.body.length > 3) {
        playerSnake.body.removeAt(0);
      }
      
      // Brief invincibility after damage
      setState(() => _isInvincible = true);
      Future.delayed(const Duration(seconds: 1), () {
        if (mounted) setState(() => _isInvincible = false);
      });
      
      // Show health warning
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Row(
            children: [
              const Icon(Icons.favorite, color: Colors.red),
              const SizedBox(width: 10),
              Text('Health: $_playerHealth / 3', style: const TextStyle(color: Colors.white, fontSize: 16)),
            ],
          ),
          backgroundColor: Colors.red.shade800,
          duration: const Duration(milliseconds: 600),
        ),
      );
    }
  }

  void _checkCollisions() {
    if (_isInvincible) return;
    
    final activeSnakes = snakes.where((s) => s.alive).toList();
    
    for (int i = 0; i < activeSnakes.length; i++) {
      for (int j = i + 1; j < activeSnakes.length; j++) {
        final snake1 = activeSnakes[i];
        final snake2 = activeSnakes[j];
        
        if ((snake1.head - snake2.head).distance < 22) {
          if (snake1.body.length > snake2.body.length + 3) {
            _eatSnake(snake1, snake2);
          } else if (snake2.body.length > snake1.body.length + 3) {
            _eatSnake(snake2, snake1);
          } else {
            // Both lose health
            if (snake1.isPlayer) _applyDamage();
            if (snake2.isPlayer) _applyDamage();
          }
        }
      }
    }
  }

  void _eatSnake(SnakeEntity winner, SnakeEntity loser) {
    if (!loser.alive) return;
    loser.alive = false;
    
    if (loser.isPlayer) {
      _applyDamage();
      return;
    }
    
    // Winner grows
    final growAmount = math.min(6, loser.body.length ~/ 2);
    for (int i = 0; i < growAmount; i++) {
      winner.body.insert(0, winner.body.first);
    }
    
    if (winner.isPlayer) {
      GameSettings.totalPoints += loser.body.length * 8;
      
      if (GameSettings.soundEnabled) {
        AudioPlayer().play(AssetSource('audio/eat.mp3'));
      }
    }
  }

  void _updateEnemyAngle(SnakeEntity enemy) {
    if (foods.isEmpty) return;
    
    final player = snakes.firstWhere((s) => s.isPlayer);
    final playerDistance = (player.head - enemy.head).distance;
    
    if (playerDistance < 180 && enemy.body.length >= player.body.length - 2) {
      // Chase player
      final direction = (player.head - enemy.head).direction;
      enemy.angle = direction + (_rnd.nextDouble() - 0.5) * 0.3;
    } else {
      // Chase nearest food
      final nearestFood = foods.reduce((a, b) {
        final da = (a.pos - enemy.head).distance;
        final db = (b.pos - enemy.head).distance;
        return da < db ? a : b;
      });
      final direction = (nearestFood.pos - enemy.head).direction;
      enemy.angle = direction + (_rnd.nextDouble() - 0.5) * 0.2;
    }
  }

  void _gameOver() {
    gameTimer?.cancel();
    movementTimer?.cancel();
    
    if (GameSettings.soundEnabled) {
      AudioPlayer().play(AssetSource('audio/die.mp3'));
    }
    if (GameSettings.vibrationEnabled) {
      Vibration.vibrate(duration: 500);
    }
    
    if (mounted) {
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => AlertDialog(
          title: const Text('💀 GAME OVER 💀', style: TextStyle(color: Colors.red)),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              Text('Points: ${GameSettings.totalPoints}', style: const TextStyle(fontSize: 20, fontWeight: FontWeight.bold)),
              Text('Level: ${GameSettings.level}', style: const TextStyle(fontSize: 16)),
              Text('High Score: ${GameSettings.highScore}', style: const TextStyle(color: Colors.yellow)),
              const SizedBox(height: 10),
              const Text('Try again to beat your best score!', textAlign: TextAlign.center),
            ],
          ),
          actions: [
            TextButton(
              onPressed: () {
                Navigator.of(context).pop();
                _resetGame();
                _startGameLoop();
              },
              style: TextButton.styleFrom(backgroundColor: Colors.green),
              child: const Text('RESTART', style: TextStyle(color: Colors.white)),
            ),
            TextButton(
              onPressed: () => Navigator.of(context).popUntil((route) => route.isFirst),
              child: const Text('MAIN MENU'),
            ),
          ],
        ),
      );
    }
  }

  @override
  void dispose() {
    backgroundMusic?.dispose();
    gameTimer?.cancel();
    movementTimer?.cancel();
    _smoothController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final playerSnake = snakes.firstWhere((s) => s.isPlayer);
    screenSize = MediaQuery.of(context).size;
    
    return Scaffold(
      body: Stack(
        children: [
          // Parallax Background
          Positioned.fill(
            child: Transform.translate(
              offset: Offset(_backgroundOffsetX, _backgroundOffsetY),
              child: Container(
                decoration: BoxDecoration(
                  gradient: RadialGradient(
                    center: Alignment.center,
                    radius: 1.5,
                    colors: [
                      _getBackgroundColor(),
                      _getBackgroundColor().withBlue(50),
                      Colors.black,
                    ],
                  ),
                ),
              ),
            ),
          ),
          
          // Game Canvas with shake effect
          Positioned.fill(
            child: Transform.translate(
              offset: Offset(_shakeOffset, _shakeOffset),
              child: GestureDetector(
                behavior: HitTestBehavior.opaque,
                onPanUpdate: (details) {
                  if (details.delta.distance > 3) {
                    setState(() {
                      angle = details.delta.direction;
                    });
                  }
                },
                child: CustomPaint(
                  painter: GamePainter(snakes, foods, screenSize),
                  size: screenSize,
                ),
              ),
            ),
          ),
          
          // Health Bar
          Positioned(
            top: 50,
            left: 20,
            child: Container(
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
              decoration: BoxDecoration(
                color: Colors.black54,
                borderRadius: BorderRadius.circular(20),
              ),
              child: Row(
                children: [
                  ...List.generate(_playerHealth, (index) => 
                    const Padding(
                      padding: EdgeInsets.symmetric(horizontal: 2),
                      child: Icon(Icons.favorite, color: Colors.red, size: 24),
                    )),
                  ...List.generate(3 - _playerHealth, (index) => 
                    const Padding(
                      padding: EdgeInsets.symmetric(horizontal: 2),
                      child: Icon(Icons.favorite_border, color: Colors.grey, size: 24),
                    )),
                ],
              ),
            ),
          ),
          
          // Score Display
          Positioned(
            top: 50,
            right: 20,
            child: Container(
              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
              decoration: BoxDecoration(
                color: Colors.black54,
                borderRadius: BorderRadius.circular(20),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.end,
