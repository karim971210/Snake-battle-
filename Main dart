                  ],
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
  
  Widget _buildSkinCard(SnakeSkin skin) {
    final isUnlocked = GameSettings.unlockedSkins[skin.id] == true;
    final isSelected = GameSettings.currentSkinId == skin.id;
    
    return Container(
      margin: const EdgeInsets.only(bottom: 12),
      decoration: BoxDecoration(
        color: Colors.white.withAlpha(30),
        borderRadius: BorderRadius.circular(15),
        border: Border.all(color: isSelected ? Colors.green : Colors.white24, width: 2),
      ),
      child: ListTile(
        leading: Container(
          width: 50,
          height: 50,
          decoration: BoxDecoration(
            color: skin.color,
            borderRadius: BorderRadius.circular(25),
            boxShadow: [BoxShadow(color: skin.color, blurRadius: 10)],
          ),
          child: const Center(child: Icon(Icons.circle, color: Colors.white, size: 30)),
        ),
        title: Text(skin.name, style: const TextStyle(color: Colors.white, fontSize: 18)),
        subtitle: Text(isUnlocked ? (isSelected ? 'Selected' : 'Tap to select') : 'Price: ${skin.price} points',
          style: TextStyle(color: isSelected ? Colors.green : Colors.white70)),
        trailing: isUnlocked 
          ? (isSelected 
              ? const Icon(Icons.check_circle, color: Colors.green, size: 30)
              : TextButton(
                  onPressed: () => _selectSkin(skin),
                  child: const Text('SELECT', style: TextStyle(color: Colors.green)),
                ))
          : TextButton(
              onPressed: () => _buySkin(skin),
              child: Text('BUY ${skin.price}', style: const TextStyle(color: Colors.orange)),
            ),
      ),
    );
  }
  
  Widget _buildBackgroundCard(BackgroundPack bg) {
    final isUnlocked = GameSettings.unlockedBackgrounds[bg.id] == true;
    final isSelected = GameSettings.currentBackground == bg.id;
    
    return Container(
      margin: const EdgeInsets.only(bottom: 12),
      decoration: BoxDecoration(
        color: Colors.white.withAlpha(30),
        borderRadius: BorderRadius.circular(15),
        border: Border.all(color: isSelected ? Colors.green : Colors.white24, width: 2),
      ),
      child: ListTile(
        leading: Container(
          width: 50,
          height: 50,
          decoration: BoxDecoration(
            gradient: RadialGradient(colors: [Colors.blue, _getBackgroundColor(bg.id)]),
            borderRadius: BorderRadius.circular(10),
          ),
        ),
        title: Text(bg.name, style: const TextStyle(color: Colors.white, fontSize: 18)),
        subtitle: Text(isUnlocked ? (isSelected ? 'Selected' : 'Tap to select') : 'Price: ${bg.price} points',
          style: TextStyle(color: isSelected ? Colors.green : Colors.white70)),
        trailing: isUnlocked
          ? (isSelected
              ? const Icon(Icons.check_circle, color: Colors.green, size: 30)
              : TextButton(
                  onPressed: () => _selectBackground(bg),
                  child: const Text('SELECT', style: TextStyle(color: Colors.green)),
                ))
          : TextButton(
              onPressed: () => _buyBackground(bg),
              child: Text('BUY ${bg.price}', style: const TextStyle(color: Colors.orange)),
            ),
      ),
    );
  }
  
  void _buySkin(SnakeSkin skin) {
    if (GameSettings.totalPoints >= skin.price) {
      setState(() {
        GameSettings.totalPoints -= skin.price;
        GameSettings.unlockedSkins[skin.id] = true;
        GameSettings.currentSkinId = skin.id;
      });
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Skin purchased!'), backgroundColor: Colors.green),
      );
    } else {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Need ${skin.price - GameSettings.totalPoints} more points!'), backgroundColor: Colors.red),
      );
    }
  }
  
  void _selectSkin(SnakeSkin skin) {
    setState(() => GameSettings.currentSkinId = skin.id);
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text('${skin.name} equipped!'), backgroundColor: Colors.green),
    );
  }
  
  void _buyBackground(BackgroundPack bg) {
    if (GameSettings.totalPoints >= bg.price) {
      setState(() {
        GameSettings.totalPoints -= bg.price;
        GameSettings.unlockedBackgrounds[bg.id] = true;
        GameSettings.currentBackground = bg.id;
      });
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Background purchased!'), backgroundColor: Colors.green),
      );
    } else {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Need ${bg.price - GameSettings.totalPoints} more points!'), backgroundColor: Colors.red),
      );
    }
  }
  
  void _selectBackground(BackgroundPack bg) {
    setState(() => GameSettings.currentBackground = bg.id);
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text('${bg.name} background equipped!'), backgroundColor: Colors.green),
    );
  }
  
  Color _getBackgroundColor(String id) {
    switch (id) {
      case 'forest': return Colors.green;
      case 'desert': return Colors.orange;
      case 'city': return Colors.blueGrey;
      case 'night': return Colors.indigo;
      case 'space': return Colors.purple;
      case 'ocean': return Colors.blue;
      case 'volcano': return Colors.red;
      case 'iceworld': return Colors.cyan;
      default: return Colors.teal;
    }
  }
